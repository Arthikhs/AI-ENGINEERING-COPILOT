# Application
APP_NAME=AI Engineering Copilot
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production

# Database
DATABASE_URL=postgresql+asyncpg://copilot:copilot123@localhost:5432/copilot_db
SYNC_DATABASE_URL=postgresql://copilot:copilot123@localhost:5432/copilot_db

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI
OPENAI_API_KEY=your-openai-api-key
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=1536
LLM_MODEL=gpt-4o
LLM_PROVIDER=openai

# Anthropic (Claude) — optional
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google Gemini — optional
GOOGLE_API_KEY=your-google-api-key

# Ollama (local) — optional, default http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# vLLM (local OpenAI-compatible) — optional
VLLM_BASE_URL=http://localhost:8001/v1

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback

# GitHub Personal Access Token (alternative to OAuth for testing)
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_WEBHOOK_SECRET=your-webhook-secret-set-in-github

# JWT
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# LangSmith
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=ai-engineering-copilot

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Slack Integration
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_DEFAULT_CHANNEL=#engineering

# Microsoft Teams Integration
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/your-teams-webhook-url
